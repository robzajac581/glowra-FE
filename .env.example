# Environment Variables Template
# Copy this file to .env (for local dev) and .env.production (for production builds)
# Fill in your values. Do not commit real keys to git.

# API URLs
REACT_APP_API_URL=http://localhost:3001
REACT_APP_CONSULTATION_REQUEST_API_URL=http://localhost:3002

# PostHog Analytics
REACT_APP_POSTHOG_KEY=your_posthog_project_key
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
REACT_APP_POSTHOG_DEV=false
