# Environment Variables Template
# Copy this file to .env (for local dev) and .env.production (for production builds)
# Fill in your values. Do not commit real keys to git.

# API URLs
REACT_APP_API_URL=http://localhost:3001
REACT_APP_CONSULTATION_REQUEST_API_URL=http://localhost:3002

# PostHog Analytics - use POSTHOG_* (not REACT_APP_) so keys stay out of exposed configs
# These are mapped to REACT_APP_POSTHOG_* at build/start time by scripts/load-env.js
POSTHOG_KEY=your_posthog_project_key
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DEV=false
